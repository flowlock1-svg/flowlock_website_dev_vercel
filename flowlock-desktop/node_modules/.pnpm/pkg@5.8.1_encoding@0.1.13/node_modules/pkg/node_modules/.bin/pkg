#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/nsj14/Downloads/flowlock-main/flowlock-desktop/node_modules/.pnpm/pkg@5.8.1_encoding@0.1.13/node_modules/pkg/node_modules:/Users/nsj14/Downloads/flowlock-main/flowlock-desktop/node_modules/.pnpm/pkg@5.8.1_encoding@0.1.13/node_modules:/Users/nsj14/Downloads/flowlock-main/flowlock-desktop/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/nsj14/Downloads/flowlock-main/flowlock-desktop/node_modules/.pnpm/pkg@5.8.1_encoding@0.1.13/node_modules/pkg/node_modules:/Users/nsj14/Downloads/flowlock-main/flowlock-desktop/node_modules/.pnpm/pkg@5.8.1_encoding@0.1.13/node_modules:/Users/nsj14/Downloads/flowlock-main/flowlock-desktop/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../lib-es5/bin.js" "$@"
else
  exec node  "$basedir/../../lib-es5/bin.js" "$@"
fi
